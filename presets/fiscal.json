{
  "name": "fiscal",
  "python": "3.14",
  "lockfile": "uv.lock",
  "required_services": ["postgres", "rabbitmq", "minio", "keycloak"],
  "forbidden_services": ["redis"],
  "required_checks": [
    "uv lock --check",
    "uv sync --locked --all-extras",
    "uv run ruff check src tests",
    "uv run ruff format --check src tests",
    "uv run mypy src",
    "uv run alembic upgrade head",
    "uv run python scripts/check_migration_rls.py",
    "uv run pytest"
  ],
  "required_conformance": ["separate database identities", "RLS fail closed", "real service integration", "recovery", "security"]
}
